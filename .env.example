# Gemini API key — required for all AI endpoints
GEMINI_API_KEY="your_gemini_api_key_here"

# Firebase Admin SDK service account JSON (stringify the JSON as a single line)
# Required for production auth. Leave unset when DEMO_MODE=true.
# FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"..."}'

# Set to "true" to bypass Firebase token verification (hackathon / local dev).
# Pass x-demo-role: analyst|reviewer|admin header to control access level.
# Defaults to "analyst" if header is absent.
DEMO_MODE=true

# Server port (default: 3001)
PORT=3001

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
